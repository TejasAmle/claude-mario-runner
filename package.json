{
  "name": "claude-mario-runner",
  "version": "0.2.0",
  "description": "Terminal platformer — Claude Code themed Mario-style runner",
  "type": "module",
  "bin": {
    "claude-mario": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --no-error-on-unmatched-pattern",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "keywords": [
    "cli",
    "game",
    "terminal",
    "platformer",
    "tui",
    "claude"
  ],
  "author": "Tejas Amle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TejasAmle/claude-mario-runner.git"
  },
  "bugs": {
    "url": "https://github.com/TejasAmle/claude-mario-runner/issues"
  },
  "homepage": "https://github.com/TejasAmle/claude-mario-runner#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.0"
  }
}
