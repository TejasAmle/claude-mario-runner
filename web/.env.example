# Upstash Redis (provisioned via Vercel Marketplace → auto-injected in prod)
# For local dev, copy to .env.local and fill from the Vercel dashboard.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# The leaderboard "namespace" — bumped only when game physics change in a
# way that invalidates older scores. Keep in sync with package.json major.
LEADERBOARD_VERSION=v0

# Minimum game version the server will accept scores from.
MIN_CLIENT_VERSION=0.2.0
